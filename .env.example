# 복사해서 .env 로 쓰고 값 채우기: cp .env.example .env
# 실배포는 강한 비밀번호로 교체
DB_NAME=chokchok
DB_USER=chokchok
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me

# CORS 허용 origin (CorsConfig). 로컬은 Vite proxy라 불필요(기본값 localhost:5173로 충분).
# 배포는 프론트가 다른 도메인이므로 배포 프론트 URL을 콤마로 지정: https://chok.vercel.app
APP_CORS_ORIGINS=http://localhost:5173
